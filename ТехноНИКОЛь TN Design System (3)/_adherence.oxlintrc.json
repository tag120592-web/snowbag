        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|red|green|blue|orange|yellow|purple)$/]",
        "message": "<Tag> tone must be one of 'neutral' | 'red' | 'green' | 'blue' | 'orange' | 'yellow' | 'purple'."
